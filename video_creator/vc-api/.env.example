# vc-api 환경변수 — .env.local 로 복사 후 실제 값 입력
# cp .env.example .env.local

PORT=5000

# MariaDB (로컬 MySQL 또는 EC2 연결 선택)
# 옵션 A: 로컬 MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_local_password
DB_NAME=ai_proposal

# 옵션 B: EC2 DB 직접 연결 (개발 테스트용)
# DB_HOST=3.34.99.69
# DB_USER=aiadmin
# DB_PASSWORD=our10680^^

# Claude AI (시나리오 생성)
ANTHROPIC_API_KEY=your_anthropic_api_key

# fal.ai (AI 영상 생성) — 없으면 Mock 자동 전환
FAL_KEY=your_fal_api_key
# 사용 모델 선택 (기본: Kling V1 Pro)
# 옵션: fal-ai/kling-video/v1/pro
#       fal-ai/kling-video/o1/reference-to-video  (캐릭터 일관성 최강)
#       fal-ai/wan                                 (저렴)
FAL_MODEL=fal-ai/kling-video/v1/pro

# 파일 저장 경로 (로컬 절대 경로)
UPLOAD_BASE_PATH=./uploads
PHOTOS_PATH=./uploads/photos
MUSIC_PATH=./uploads/music
RENDERED_PATH=./uploads/rendered
MUSIC_LIBRARY_PATH=./uploads/music-library

# 서버 공개 URL (파일 URL 생성용)
SERVER_BASE_URL=http://localhost:5000

# 관리자 서버 (Team C, 주문 연동용)
ADMIN_SERVER_URL=http://localhost:8080

# ffmpeg 경로 (비워두면 ffmpeg-static 자동 사용)
# FFMPEG_PATH=/usr/local/bin/ffmpeg
